# ===== Primary LLM（必填 — at least one provider key required）=====
LLM_API_KEY=your_openai_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-5.4-mini

# ===== Multi-Provider API Keys =====
# Configure all providers you have access to. Models auto-failover between them.
# If a provider's API returns errors or hits rate limits, the next provider is tried.
OPENAI_API_KEY=your_openai_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=your_anthropic_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

GEMINI_API_KEY=your_gemini_key_here
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# ===== Cost Tier =====
# "cheap" | "medium" | "expensive" — also switchable in the UI at runtime.
#
# cheap ($0.05-0.15/run):
#   Reports: gpt-5.4-mini -> gemini-3.0-flash -> claude-haiku-4-5
#   Bulk:    gpt-5.4-nano -> gemini-3.1-flash-lite -> gpt-5.4-mini
#
# medium ($0.30-0.80/run):
#   Reports: claude-sonnet-4-6 -> gpt-5.4 -> gemini-3.0-flash
#   Bulk:    gpt-5.4-nano -> gemini-3.1-flash-lite -> claude-haiku-4-5
#
# expensive ($0.50-1.50/run):
#   Reports: claude-sonnet-4-6 -> gpt-5.4 -> claude-haiku-4-5
#   Bulk:    gpt-5.4-mini -> gemini-3.0-flash -> claude-haiku-4-5
#
COST_TIER=cheap

# ===== Token Budget =====
# Max tokens per pipeline run. Auto-stops when exceeded. 0=unlimited.
TOKEN_BUDGET_MAX=500000